# Choose ONE provider and fill in its key. If left blank, the app uses
# a built-in rule-based mock LLM so the pipeline still runs offline.

OPENAI_API_KEY=
GOOGLE_API_KEY=

# Which provider to use: "openai", "gemini", or "mock"
LLM_PROVIDER=

# Database
DATABASE_URL=sqlite:///data/finance.db

# App
LOG_LEVEL=INFO
